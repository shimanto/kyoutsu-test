{
  "name": "kyoutsu-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kyoutsu-db",
      "database_id": "placeholder-replace-after-create"
    }
  ],
  "vars": {
    "JWT_SECRET": "",
    "LINE_CHANNEL_ID": "",
    "LINE_CHANNEL_SECRET": "",
    "LINE_MESSAGING_CHANNEL_ACCESS_TOKEN": ""
  },
  "triggers": {
    "crons": [
      "0 23 * * *",
      "0 11 * * *"
    ]
  }
}
